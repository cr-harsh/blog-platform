<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>DevBlog - Share Your Thoughts</title>
  <link rel="stylesheet" href="/style.css">
</head>
<body>
  <!-- Navbar -->
  <nav class="navbar">
    <div class="container nav-container">
      <a href="/" class="nav-brand">✍️ <span>DevBlog</span></a>
      <div class="nav-menu">
        <a href="/" class="nav-link">Home</a>
        <a href="/featured" class="nav-link">Featured Blogs</a>
        <a href="/add-blog" class="btn btn-primary">Add Blog</a>
      </div>
    </div>
  </nav>

  <!-- Main Content -->
  <main class="container">
    <!-- Page Header -->
    <header class="page-header">
      <h1>DevBlog Platform</h1>
      <p>Explore stories, thinking, and expertise from writers on any topic.</p>
      <span class="blog-count-badge">Total Blogs: <%= blogs.length %></span>
    </header>

    <% if (blogs.length === 0) { %>
      <!-- Empty State -->
      <div class="empty-state">
        <div class="empty-state-icon">📝</div>
        <h2 class="empty-state-title">No blogs found</h2>
        <p class="empty-state-desc">Get started by creating your very first blog post right now.</p>
        <a href="/add-blog" class="btn btn-primary">Write a Blog</a>
      </div>
    <% } else { %>
      <!-- Blog Cards Grid -->
      <section class="blog-grid">
        <% blogs.forEach((blog) => { %>
          <article class="blog-card">
            <div class="blog-card-meta">
              <span class="badge badge-<%= blog.category.toLowerCase() %>"><%= blog.category %></span>
              <time class="blog-card-date"><%= blog.date %></time>
            </div>
            
            <div class="blog-card-body">
              <h2 class="blog-card-title">
                <a href="/blog/<%= blog._id %>"><%= blog.title %></a>
              </h2>
              <p class="blog-card-desc"><%= blog.shortDescription %></p>
              
              <!-- Hidden block to preserve required blog.content EJS variable without cluttering card layout -->
              <div style="display: none;"><%= blog.content %></div>
              
              <div>
                <a href="/blog/<%= blog._id %>" class="read-more-link">Read More</a>
              </div>
            </div>

            <div class="blog-card-actions">
              <!-- Toggle Featured Button -->
              <form action="/toggle-featured/<%= blog._id %>" method="post" class="action-form">
                <button type="submit" class="btn-featured-toggle <%= blog.isFeatured ? 'featured-active' : 'featured-inactive' %>" title="Toggle Featured Status">
                  <%= blog.isFeatured ? '★ Featured' : '☆ Feature' %>
                </button>
              </form>

              <!-- Edit Link -->
              <a href="/edit-blog/<%= blog._id %>" class="btn btn-outline" title="Edit Blog">Edit</a>

              <!-- Delete Form -->
              <form action="/delete-blog/<%= blog._id %>" method="post" class="action-form" onsubmit="return confirm('Are you sure you want to delete this blog?');">
                <button type="submit" class="btn btn-delete" title="Delete Blog">🗑️ Delete</button>
              </form>
            </div>
          </article>
        <% }) %>
      </section>
    <% } %>
  </main>
</body>
</html>